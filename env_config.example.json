{
  "gpio": {
    "wifi_mode_pin": 5,
    "webserver_pin": 6,
    "mqtt_pin": 7
  },
  "wifi": {
    "ap_ssid": "Spectrometer-AP",
    "ap_passphrase": "changeme",
    "ap_channel": 6,
    "sta_config_path": "/etc/wpa_supplicant/wpa_supplicant.conf"
  },
  "webserver": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "mqtt": {
    "broker": "YOUR_MQTT_BROKER_IP",
    "port": 1883,
    "user": "YOUR_MQTT_USERNAME",
    "pass": "YOUR_MQTT_PASSWORD",
    "cmd_topic": "lab/monocamera/cmd/",
    "state_topic": "lab/monocamera/state/"
  },
  "rtsp": {
    "url": "rtsp://YOUR_MEDIAMTX_HOST:8554/mystream"
  },
  "paths": {
    "home": "/home/raspberry",
    "camera_config": "/home/raspberry/spectrometer_sc132-master/camera_config.json",
    "i2c_tool": "/home/raspberry/spectrometer_sc132-master/raspberrypi_v4l2/mv_tools_rpi/mv_mipi_i2c_new.sh"
  },
  "device": {
    "video": "/dev/video0",
    "i2c_bus": "10"
  },
  "services": {
    "mediamtx": "mediamtx.service",
    "rtsp_camera": "rtsp-camera.service"
  },
  "spectrometer": {
    "cmd_topic": "lab/spectrometer/cmd/",
    "state_topic": "lab/spectrometer/state/",
    "config_path": "/home/raspberry/spectrometer_sc132-master/spectrometer/spectrometer_config.json"
  },
  "debug": false
}
